{
  "name": "private-blockchain",
  "version": "1.0.0",
  "description": "A complete private blockchain with native currency, MetaMask integration",
  "main": "src/index.js",
  "scripts": {
    "start": "API_PORT=3001 P2P_PORT=5001 RPC_PORT=8545 node src/index.js",
    "start:api": "API_PORT=3001 node src/server/api.js",
    "start:p2p": "P2P_PORT=5001 node src/server/p2p.js",
    "start:rpc": "RPC_PORT=8545 node src/server/rpc.js",
    "start:protocol": "PROTOCOL_PORT=3002 node src/server/protocol.js",
    "start:auth": "AUTH_PORT=3003 node src/server/auth.js",
    "start:admin": "DOCUMENT_PORT=3004 ADMIN_PORT=3005 node src/server/admin.js",
    "test:lifecycle": "PROTOCOL_URL=http://localhost:3002 node scripts/lifecycle-test.js",
    "clear": "rm -rf node_modules package-lock.json"
  },
  "keywords": [
    "blockchain",
    "cryptocurrency",
    "metamask",
    "smart-contracts",
    "private-blockchain"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@ethereumjs/blockchain": "^10.1.0",
    "@ethereumjs/common": "^10.1.0",
    "@ethereumjs/tx": "^10.1.0",
    "@ethereumjs/vm": "^10.1.0",
    "@ledgerhq/hw-app-eth": "^6.39.0",
    "@ledgerhq/hw-transport-node-hid": "^6.29.0",
    "body-parser": "^2.2.1",
    "elliptic": "^6.6.1",
    "ethereumjs-util": "^7.1.5",
    "express": "^5.1.0",
    "level": "^10.0.0",
    "merkle-patricia-tree": "^4.2.4",
    "sha256": "^0.2.0",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "axios": "^1.13.2"
  }
}
